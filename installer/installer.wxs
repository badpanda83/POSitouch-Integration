<?xml version="1.0" encoding="UTF-8"?>
<!--
  installer.wxs - WiX Toolset v4 MSI definition for the Rooam POS Agent.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="Rooam POS Agent"
    Manufacturer="Rooam Inc."
    Version="1.0.0"
    UpgradeCode="3F8B2D1A-4C5E-4F6A-8B7D-9E0F1A2B3C4D"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow upgrades and prevent downgrades -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Media / cabinet -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Properties set during install -->
    <!-- Secure="yes" ensures these values are passed from the UI process to the
         elevated server (execute) process in a per-machine install via
         SecureCustomProperties. Without this, all user-supplied values arrive
         empty in InstallExecuteSequence and config_writer.exe writes a blank
         rooam_config.json. -->
    <Property Id="INSTALLDIR" Value="C:\Program Files\Rooam\POSAgent\" />
    <Property Id="LOCATION_NAME"    Secure="yes" />
    <Property Id="LOCATION_ID"      Secure="yes" />
    <Property Id="LOCATION_ADDRESS" Secure="yes" />
    <Property Id="LOCATION_PHONE"   Secure="yes" />
    <Property Id="LOCATION_EMAIL"   Secure="yes" />
    <Property Id="EMPLOYEE_ID"      Secure="yes" />
    <Property Id="TENDER_ID"        Secure="yes" />
    <Property Id="API_KEY"          Secure="yes" />
    <Property Id="SPCWIN_PATH"     Value="C:\SC\spcwin.exe"  Secure="yes" />
    <Property Id="XML_DIR"         Value="C:\SC\XML"         Secure="yes" />
    <Property Id="XML_CLOSE_DIR"   Value="C:\SC\XMLCLOSE"    Secure="yes" />
    <Property Id="XML_INORDER_DIR" Value="C:\SC\INORDER"     Secure="yes" />
    <Property Id="POS_TYPE"          Value="positouch"        Secure="yes" />
    <Property Id="MICROS_TS_URL"     Secure="yes" />
    <Property Id="MICROS_DB_HOST"    Secure="yes" />
    <Property Id="MICROS_DB_NAME"    Secure="yes" />
    <Property Id="MICROS_DB_USER"    Secure="yes" />
    <Property Id="MICROS_DB_PASSWORD" Secure="yes" />

    <!-- Directory tree -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="RooamDir" Name="Rooam">
        <Directory Id="INSTALLDIR" Name="POSAgent" />
      </Directory>
    </StandardDirectory>

    <!-- Feature -->
    <Feature Id="ProductFeature" Title="Rooam POS Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- Components -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">

      <!-- Agent binary + Windows Service -->
      <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="AgentExeFile"
              Source="out\POSitouch-Integration.exe"
              KeyPath="yes"
              Name="POSitouch-Integration.exe" />
        <ServiceInstall
          Id="InstallService"
          Name="RooamPOSAgent"
          DisplayName="Rooam POS Agent"
          Description="Rooam POS Integration Agent - syncs POS data to the cloud."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="LocalSystem"
          Arguments="-config &quot;[INSTALLDIR]rooam_config.json&quot;" />
        <ServiceControl
          Id="StartService"
          Name="RooamPOSAgent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

      <!-- config_writer helper -->
      <Component Id="ConfigWriterExe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="ConfigWriterFile"
              Source="out\config_writer.exe"
              KeyPath="yes"
              Name="config_writer.exe" />
      </Component>

      <!-- detect.ps1 helper -->
      <Component Id="DetectScript" Guid="C3D4E5F6-A7B8-9012-CDEF-012345678902">
        <File Id="DetectScriptFile"
              Source="detect.ps1"
              KeyPath="yes"
              Name="detect.ps1" />
      </Component>

    </ComponentGroup>

    <!-- Custom actions -->
    <!-- Write config for POSitouch.
         Execute="deferred" + Impersonate="no": runs in the elevated installer
         server process AFTER InstallFiles has committed files to disk, so
         [INSTALLDIR]config_writer.exe is guaranteed to exist when this fires.
         Immediate CAs run before files land, which caused "file not found" on
         perMachine installs. -->
    <CustomAction
      Id="CA_WriteConfig_POSitouch"
      Directory="INSTALLDIR"
      ExeCommand="&quot;[INSTALLDIR]config_writer.exe&quot; -pos-type positouch -location-name &quot;[LOCATION_NAME]&quot; -location-id &quot;[LOCATION_ID]&quot; -address &quot;[LOCATION_ADDRESS]&quot; -phone &quot;[LOCATION_PHONE]&quot; -email &quot;[LOCATION_EMAIL]&quot; -employee-id &quot;[EMPLOYEE_ID]&quot; -tender-id &quot;[TENDER_ID]&quot; -api-key &quot;[API_KEY]&quot; -spcwin-path &quot;[SPCWIN_PATH]&quot; -xml-dir &quot;[XML_DIR]&quot; -xml-close-dir &quot;[XML_CLOSE_DIR]&quot; -xml-inorder-dir &quot;[XML_INORDER_DIR]&quot; -output &quot;[INSTALLDIR]rooam_config.json&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <!-- Write config for MICROS 3700 -->
    <CustomAction
      Id="CA_WriteConfig_MICROS"
      Directory="INSTALLDIR"
      ExeCommand="&quot;[INSTALLDIR]config_writer.exe&quot; -pos-type micros3700 -location-name &quot;[LOCATION_NAME]&quot; -location-id &quot;[LOCATION_ID]&quot; -address &quot;[LOCATION_ADDRESS]&quot; -phone &quot;[LOCATION_PHONE]&quot; -email &quot;[LOCATION_EMAIL]&quot; -employee-id &quot;[EMPLOYEE_ID]&quot; -tender-id &quot;[TENDER_ID]&quot; -api-key &quot;[API_KEY]&quot; -micros-ts-url &quot;[MICROS_TS_URL]&quot; -micros-db-host &quot;[MICROS_DB_HOST]&quot; -micros-db-name &quot;[MICROS_DB_NAME]&quot; -micros-db-user &quot;[MICROS_DB_USER]&quot; -micros-db-password &quot;[MICROS_DB_PASSWORD]&quot; -output &quot;[INSTALLDIR]rooam_config.json&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <CustomAction
      Id="CA_HealthCheck"
      Directory="INSTALLDIR"
      ExeCommand="powershell.exe -NonInteractive -NoProfile -Command &quot;$ok=$false; for($i=0;$i -lt 10;$i++){try{$r=Invoke-RestMethod -Uri 'http://localhost:8080/health' -TimeoutSec 5 -ErrorAction Stop; if($r.status -eq 'ok'){$ok=$true;break}}catch{}; Start-Sleep -Seconds 3}; if(-not $ok){Write-Warning 'Health check: agent did not respond within 30 s - check Event Viewer'}&quot;"
      Execute="commit"
      Return="ignore"
      Impersonate="no" />

    <!-- Install sequence -->
    <InstallExecuteSequence>
      <Custom Action="CA_WriteConfig_POSitouch" After="InstallFiles" Condition="NOT Installed AND POS_TYPE = &quot;positouch&quot;" />
      <Custom Action="CA_WriteConfig_MICROS"    After="InstallFiles" Condition="NOT Installed AND POS_TYPE = &quot;micros3700&quot;" />
      <Custom Action="CA_HealthCheck"           After="StartServices" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- UI -->
    <UI Id="RooamUI">
      <UIRef Id="WixUI_Common" />

      <TextStyle Id="WixUI_Font_Normal"  FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger"  FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title"   FaceName="Tahoma" Size="9" Bold="yes" />
      <TextStyle Id="WixUI_Font_Smaller" FaceName="Tahoma" Size="7" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode"    Value="Full" />

      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="VerifyReadyDlg" />
      <DialogRef Id="RooamConfigDlg" />
      <DialogRef Id="POSTypeDlg" />
      <DialogRef Id="POSPathsDlg" />
      <DialogRef Id="MICROSDlg" />

      <!-- Override WelcomeDlg Next to go to our first custom dialog -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="RooamConfigDlg" Condition="1" />

      <!-- VerifyReadyDlg Back → MICROSDlg when MICROS, → POSPathsDlg otherwise -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MICROSDlg"   Order="1" Condition="POS_TYPE = &quot;micros3700&quot;" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="POSPathsDlg" Order="2" Condition="POS_TYPE &lt;&gt; &quot;micros3700&quot;" />

      <!-- Install UI sequence -->
      <InstallUISequence>
        <Show Dialog="WelcomeDlg"  After="CostFinalize" Condition="NOT Installed" />
        <Show Dialog="ResumeDlg"   After="CostFinalize" Condition="Installed AND RESUME" />
        <Show Dialog="ProgressDlg" After="CostFinalize" Condition="Installed AND NOT RESUME" />
      </InstallUISequence>
    </UI>

  </Package>
</Wix>