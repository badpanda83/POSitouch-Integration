<?xml version="1.0" encoding="UTF-8"?>
<!--
  installer.wxs - WiX Toolset v4 MSI definition for the Rooam POS Agent.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="Rooam POS Agent"
    Manufacturer="Rooam Inc."
    Version="1.0.0"
    UpgradeCode="3F8B2D1A-4C5E-4F6A-8B7D-9E0F1A2B3C4D"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow upgrades and prevent downgrades -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Media / cabinet -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Properties set during install -->
    <Property Id="INSTALLDIR" Value="C:\Program Files\Rooam\POSAgent\" />
    <Property Id="LOCATION_NAME"    Admin="yes" />
    <Property Id="LOCATION_ID"      Admin="yes" />
    <Property Id="LOCATION_ADDRESS" Admin="yes" />
    <Property Id="LOCATION_PHONE"   Admin="yes" />
    <Property Id="LOCATION_EMAIL"   Admin="yes" />
    <Property Id="EMPLOYEE_ID"      Admin="yes" />
    <Property Id="TENDER_ID"        Admin="yes" />
    <Property Id="API_KEY"          Secure="yes" />
    <Property Id="SPCWIN_PATH"     Value="C:\SC\spcwin.exe" />
    <Property Id="XML_DIR"         Value="C:\SC\XML" />
    <Property Id="XML_CLOSE_DIR"   Value="C:\SC\XMLCLOSE" />
    <Property Id="XML_INORDER_DIR" Value="C:\SC\INORDER" />

    <!-- Directory tree -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="RooamDir" Name="Rooam">
        <Directory Id="INSTALLDIR" Name="POSAgent" />
      </Directory>
    </StandardDirectory>

    <!-- Feature -->
    <Feature Id="ProductFeature" Title="Rooam POS Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- Components -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">

      <!-- Agent binary + Windows Service -->
      <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="AgentExeFile"
              Source="out\POSitouch-Integration.exe"
              KeyPath="yes"
              Name="POSitouch-Integration.exe" />
        <ServiceInstall
          Id="InstallService"
          Name="RooamPOSAgent"
          DisplayName="Rooam POS Agent"
          Description="Rooam POS Integration Agent - syncs POS data to the cloud."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="LocalSystem"
          Arguments="-config &quot;[INSTALLDIR]rooam_config.json&quot;" />
        <ServiceControl
          Id="StartService"
          Name="RooamPOSAgent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

      <!-- config_writer helper -->
      <Component Id="ConfigWriterExe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="ConfigWriterFile"
              Source="out\config_writer.exe"
              KeyPath="yes"
              Name="config_writer.exe" />
      </Component>

      <!-- detect.ps1 helper -->
      <Component Id="DetectScript" Guid="C3D4E5F6-A7B8-9012-CDEF-012345678902">
        <File Id="DetectScriptFile"
              Source="detect.ps1"
              KeyPath="yes"
              Name="detect.ps1" />
      </Component>

    </ComponentGroup>

    <!-- Custom actions -->
    <CustomAction
      Id="CA_WriteConfig"
      Directory="INSTALLDIR"
      ExeCommand="&quot;[INSTALLDIR]config_writer.exe&quot; -location-name &quot;[LOCATION_NAME]&quot; -location-id &quot;[LOCATION_ID]&quot; -address &quot;[LOCATION_ADDRESS]&quot; -phone &quot;[LOCATION_PHONE]&quot; -email &quot;[LOCATION_EMAIL]&quot; -employee-id &quot;[EMPLOYEE_ID]&quot; -tender-id &quot;[TENDER_ID]&quot; -api-key &quot;[API_KEY]&quot; -spcwin-path &quot;[SPCWIN_PATH]&quot; -xml-dir &quot;[XML_DIR]&quot; -xml-close-dir &quot;[XML_CLOSE_DIR]&quot; -xml-inorder-dir &quot;[XML_INORDER_DIR]&quot; -output &quot;[INSTALLDIR]rooam_config.json&quot;"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <CustomAction
      Id="CA_HealthCheck"
      Directory="INSTALLDIR"
      ExeCommand="powershell.exe -NonInteractive -NoProfile -Command &quot;$ok=$false; for($i=0;$i -lt 10;$i++){try{$r=Invoke-RestMethod -Uri 'http://localhost:8080/health' -TimeoutSec 5 -ErrorAction Stop; if($r.status -eq 'ok'){$ok=$true;break}}catch{}; Start-Sleep -Seconds 3}; if(-not $ok){Write-Warning 'Health check: agent did not respond within 30 s - check Event Viewer'}&quot;"
      Execute="commit"
      Return="ignore"
      Impersonate="no" />

    <!-- Install sequence -->
    <InstallExecuteSequence>
      <Custom Action="CA_WriteConfig" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="CA_HealthCheck" After="StartServices" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- UI -->
    <UI Id="RooamUI">
      <UIRef Id="WixUI_Common" />

      <TextStyle Id="WixUI_Font_Normal"  FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger"  FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title"   FaceName="Tahoma" Size="9" Bold="yes" />
      <TextStyle Id="WixUI_Font_Smaller" FaceName="Tahoma" Size="7" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode"    Value="Full" />

      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="VerifyReadyDlg" />
      <DialogRef Id="RooamConfigDlg" />
      <DialogRef Id="POSPathsDlg" />

      <!-- WelcomeDlg: Next goes to RooamConfigDlg -->
      <Publish Dialog="WelcomeDlg" Control="Next"   Event="NewDialog"   Value="RooamConfigDlg" Condition="1" />
      <Publish Dialog="WelcomeDlg" Control="Cancel" Event="SpawnDialog" Value="CancelDlg"       Condition="1" />

      <!-- RooamConfigDlg: Back goes to WelcomeDlg (also set in RooamConfigDlg.wxs) -->
      <Publish Dialog="RooamConfigDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Condition="1" />

      <!-- VerifyReadyDlg: Back goes to POSPathsDlg -->
      <Publish Dialog="VerifyReadyDlg" Control="Back"    Event="NewDialog"   Value="POSPathsDlg" Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Install" Event="EndDialog"   Value="Return"      Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Cancel"  Event="SpawnDialog" Value="CancelDlg"   Condition="1" />

      <!-- Install UI sequence -->
      <InstallUISequence>
        <Show Dialog="WelcomeDlg"  After="CostFinalize" Condition="NOT Installed" />
        <Show Dialog="ResumeDlg"   After="CostFinalize" Condition="Installed AND RESUME" />
        <Show Dialog="ProgressDlg" After="CostFinalize" Condition="Installed AND NOT RESUME" />
      </InstallUISequence>
    </UI>

  </Package>
</Wix>