<?xml version="1.0" encoding="UTF-8"?>
<!--
  installer.wxs — WiX Toolset v4 MSI definition for the Rooam POS Agent.

  Build:
      wix build installer.wxs -o out/RooamPOSAgent-Setup.msi

  The MSI will:
    1. Install POSitouch-Integration.exe to
         C:\Program Files\Rooam\POSAgent\
    2. Run config_writer.exe to write a configured rooam_config.json
       into the same directory (populated from installer properties).
    3. Register a Windows Service named "RooamPOSAgent" that starts
       automatically.
    4. Perform a post-install health check via
         GET http://localhost:8080/health
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="Rooam POS Agent"
    Manufacturer="Rooam Inc."
    Version="1.0.0"
    UpgradeCode="3F8B2D1A-4C5E-4F6A-8B7D-9E0F1A2B3C4D"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow upgrades and prevent downgrades -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <!-- ------------------------------------------------------------------ -->
    <!-- Media / cabinet                                                      -->
    <!-- ------------------------------------------------------------------ -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ------------------------------------------------------------------ -->
    <!-- Properties set during install (can be overridden on command line)   -->
    <!-- ------------------------------------------------------------------ -->
    <Property Id="INSTALLDIR" Value="C:\Program Files\Rooam\POSAgent\" />

    <!-- Location settings -->
    <Property Id="LOCATION_NAME"    Value="" />
    <Property Id="LOCATION_ADDRESS" Value="" />
    <Property Id="LOCATION_PHONE"   Value="" />
    <Property Id="LOCATION_EMAIL"   Value="" />

    <!-- Rooam credentials -->
    <Property Id="EMPLOYEE_ID" Value="" />
    <Property Id="TENDER_ID"   Value="" />
    <Property Id="API_KEY"     Value="" Secure="yes" />

    <!-- POSitouch paths (populated by detect.ps1 or entered by user) -->
    <Property Id="SPCWIN_PATH"     Value="C:\SC\spcwin.exe" />
    <Property Id="XML_DIR"         Value="C:\SC\XML" />
    <Property Id="XML_CLOSE_DIR"   Value="C:\SC\XMLCLOSE" />
    <Property Id="XML_INORDER_DIR" Value="C:\SC\INORDER" />

    <!-- ------------------------------------------------------------------ -->
    <!-- Directory tree                                                       -->
    <!-- ------------------------------------------------------------------ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="RooamDir"    Name="Rooam">
        <Directory Id="INSTALLDIR" Name="POSAgent" />
      </Directory>
    </StandardDirectory>

    <!-- ------------------------------------------------------------------ -->
    <!-- Feature                                                              -->
    <!-- ------------------------------------------------------------------ -->
    <Feature Id="ProductFeature" Title="Rooam POS Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- ------------------------------------------------------------------ -->
    <!-- Components                                                           -->
    <!-- ------------------------------------------------------------------ -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">

      <!-- Agent binary + Windows Service registration in same component -->
      <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="AgentExeFile"
              Source="out\POSitouch-Integration.exe"
              KeyPath="yes"
              Name="POSitouch-Integration.exe" />
        <ServiceInstall
          Id="InstallService"
          Name="RooamPOSAgent"
          DisplayName="Rooam POS Agent"
          Description="Rooam POS Integration Agent — syncs POS data to the cloud."
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="LocalSystem"
          Arguments="-config &quot;[INSTALLDIR]rooam_config.json&quot;" />
        <ServiceControl
          Id="StartService"
          Name="RooamPOSAgent"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

      <!-- config_writer helper (used during install, safe to keep on disk) -->
      <Component Id="ConfigWriterExe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="ConfigWriterFile"
              Source="out\config_writer.exe"
              KeyPath="yes"
              Name="config_writer.exe" />
      </Component>

      <!-- detect.ps1 helper — kept in install dir for re-detection -->
      <Component Id="DetectScript" Guid="C3D4E5F6-A7B8-9012-CDEF-012345678902">
        <File Id="DetectScriptFile"
              Source="detect.ps1"
              KeyPath="yes"
              Name="detect.ps1" />
      </Component>

    </ComponentGroup>

    <!-- ------------------------------------------------------------------ -->
    <!-- Custom actions                                                       -->
    <!-- ------------------------------------------------------------------ -->

    <!--
      CA_WriteConfig: invoke config_writer.exe after the files are installed
      to write rooam_config.json with the values from installer properties.
    -->
    <CustomAction
      Id="CA_WriteConfig"
      Directory="INSTALLDIR"
      ExeCommand="&quot;[INSTALLDIR]config_writer.exe&quot; -location-name &quot;[LOCATION_NAME]&quot; -address &quot;[LOCATION_ADDRESS]&quot; -phone &quot;[LOCATION_PHONE]&quot; -email &quot;[LOCATION_EMAIL]&quot; -employee-id &quot;[EMPLOYEE_ID]&quot; -tender-id &quot;[TENDER_ID]&quot; -api-key &quot;[API_KEY]&quot; -spcwin-path &quot;[SPCWIN_PATH]&quot; -xml-dir &quot;[XML_DIR]&quot; -xml-close-dir &quot;[XML_CLOSE_DIR]&quot; -xml-inorder-dir &quot;[XML_INORDER_DIR]&quot; -output &quot;[INSTALLDIR]rooam_config.json&quot;"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <!--
      CA_HealthCheck: poll http://localhost:8080/health after the service
      starts via PowerShell. Retries up to 10 times with 3-second pauses
      (30 s total grace period). Uses Return="ignore" so a slow start does
      not roll back the install — the user can check Event Viewer manually.
    -->
    <CustomAction
      Id="CA_HealthCheck"
      Directory="INSTALLDIR"
      ExeCommand="powershell.exe -NonInteractive -NoProfile -Command &quot;$ok=$false; for($i=0;$i -lt 10;$i++){try{$r=Invoke-RestMethod -Uri 'http://localhost:8080/health' -TimeoutSec 5 -ErrorAction Stop; if($r.status -eq 'ok'){$ok=$true;break}}catch{}; Start-Sleep -Seconds 3}; if(-not $ok){Write-Warning 'Health check: agent did not respond within 30 s — check Event Viewer'}&quot;"
      Execute="commit"
      Return="ignore"
      Impersonate="no" />

    <!-- ------------------------------------------------------------------ -->
    <!-- Install sequence                                                     -->
    <!-- ------------------------------------------------------------------ -->
    <InstallExecuteSequence>
      <!-- Write config after files are laid down but before service starts -->
      <Custom Action="CA_WriteConfig" After="InstallFiles">NOT Installed</Custom>
      <!-- Health check after everything (including service start) -->
      <Custom Action="CA_HealthCheck" After="StartServices">NOT Installed</Custom>
    </InstallExecuteSequence>

    <!-- ------------------------------------------------------------------ -->
    <!-- UI — minimal wizard asking for the key properties                   -->
    <!-- ------------------------------------------------------------------ -->
    <UI>
      <UIRef Id="WixUI_Minimal" />
    </UI>

  </Package>
</Wix>
