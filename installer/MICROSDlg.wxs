<?xml version="1.0" encoding="UTF-8"?>
<!--
  MICROSDlg.wxs - Custom WiX v4 dialog: MICROS 3700 connection settings
  Collects Transaction Services URL, DB host/name/user/password.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Fragment>
    <UI>
      <Dialog Id="MICROSDlg" Width="370" Height="320" Title="[ProductName] Setup">

        <!-- Banner -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="yes" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Title -->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}MICROS 3700 Configuration" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="340" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="Enter the MICROS 3700 connection settings for this location." />
        </Control>

        <!-- Transaction Services URL -->
        <Control Id="TsUrlLabel" Type="Text" X="25" Y="58" Width="200" Height="10">
          <Text Value="&amp;Transaction Services URL:" />
        </Control>
        <Control Id="TsUrlEdit" Type="Edit" X="25" Y="70" Width="320" Height="18" Property="MICROS_TS_URL" Text="http://micros-server:8008/TransactionServices" />

        <!-- Database Host -->
        <Control Id="DbHostLabel" Type="Text" X="25" Y="96" Width="200" Height="10">
          <Text Value="&amp;Database Host:" />
        </Control>
        <Control Id="DbHostEdit" Type="Edit" X="25" Y="108" Width="320" Height="18" Property="MICROS_DB_HOST" Text="{80}" />

        <!-- Database Name -->
        <Control Id="DbNameLabel" Type="Text" X="25" Y="134" Width="200" Height="10">
          <Text Value="&amp;Database Name:" />
        </Control>
        <Control Id="DbNameEdit" Type="Edit" X="25" Y="146" Width="320" Height="18" Property="MICROS_DB_NAME" Text="{80}" />

        <!-- Database User -->
        <Control Id="DbUserLabel" Type="Text" X="25" Y="172" Width="200" Height="10">
          <Text Value="&amp;Database User:" />
        </Control>
        <Control Id="DbUserEdit" Type="Edit" X="25" Y="184" Width="320" Height="18" Property="MICROS_DB_USER" Text="{80}" />

        <!-- Database Password -->
        <Control Id="DbPasswordLabel" Type="Text" X="25" Y="210" Width="200" Height="10">
          <Text Value="&amp;Database Password:" />
        </Control>
        <Control Id="DbPasswordEdit" Type="Edit" X="25" Y="222" Width="320" Height="18" Property="MICROS_DB_PASSWORD" Password="yes" Text="{80}" />

        <!-- Bottom line -->
        <Control Id="BottomLine" Type="Line" X="0" Y="284" Width="370" Height="0" />

        <!-- Buttons -->
        <Control Id="Back" Type="PushButton" X="180" Y="293" Width="56" Height="17" Text="&lt; &amp;Back">
          <Publish Event="NewDialog" Value="POSTypeDlg" Condition="1" />
        </Control>

        <Control Id="Next" Type="PushButton" X="236" Y="293" Width="56" Height="17" Default="yes" Text="&amp;Next >">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="MICROS_TS_URL AND MICROS_DB_HOST AND MICROS_DB_NAME AND MICROS_DB_USER AND MICROS_DB_PASSWORD" />
        </Control>

        <Control Id="Cancel" Type="PushButton" X="304" Y="293" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>

      </Dialog>
    </UI>
  </Fragment>

</Wix>
